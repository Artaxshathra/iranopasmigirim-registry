<?xml version="1.0" encoding="UTF-8"?>
<!--
  Tizen TV web-app manifest. The XML namespaces and the tizen:application
  element are required by the Tizen platform — removing any of them makes
  the package invalid at install time.

  - id: stable application id, must be globally unique. The 10-char prefix
        before the dot is the package id; the suffix is the app id within
        that package. Both are constants for the lifetime of the app — do
        not regenerate them, or upgrades on the TV become re-installs that
        wipe user state.
  - required_version: minimum Tizen TV platform. 6.0 covers 2021+ TVs and
        is the floor we target.
  - profile name="tv-samsung": tells the SDK packager to build for TV, not
        mobile or wearable.
  - tizen:setting screen-orientation="landscape": TVs are always landscape;
        prevents the platform from probing rotation events.
  - access origin="...": the per-app whitelist enforced by the Tizen
        WebView. Must include every origin the app talks to. Mirrors the
        connect-src/media-src in the meta CSP.
  - allow-navigation: prevents the app from navigating away from its own
        bundle if a stray link were ever clicked.
-->
<widget xmlns="http://www.w3.org/ns/widgets"
        xmlns:tizen="http://tizen.org/ns/widgets"
        id="http://irannrtv.live/inrtv"
        version="0.1.0"
        viewmodes="maximized">
  <tizen:application id="iNRTVlive0.INRTVLive"
                     package="iNRTVlive0"
                     required_version="6.0"/>
  <name>INRTV Live</name>
  <description>Iranian National Radio &amp; TV — live stream</description>
  <author email="contact@irannrtv.live" href="https://irannrtv.live">INRTV</author>
  <icon src="icon.png"/>
  <content src="index.html"/>
  <tizen:profile name="tv-samsung"/>
  <!-- Platform splash: Tizen draws this image, centered on black, between
       app launch and the first WebView paint. Without it the TV shows a
       blank black flash for ~600 ms. Reusing icon.png keeps the visual
       chain (launcher tile → splash → in-app branding) coherent. The
       schema element is <tizen:splash> (singular, no wrapper) — the
       <tizen:splash-screens> form documented for mobile profiles is
       rejected by the TV schema. -->
  <tizen:splash src="icon.png"/>
  <tizen:setting screen-orientation="landscape"
                 background-support="disable"
                 encryption="disable"
                 install-location="auto"
                 hwkey-event="enable"/>
  <tizen:metadata key="http://samsung.com/tv/metadata/use.legacy.event" value="false"/>
  <!-- Tizen's WebView ignores the <meta http-equiv> CSP in index.html and
       substitutes default-src *, which (a) is wide open and (b) blocks blob:
       URLs. The MediaSource that hls.js feeds to <video> is a blob:, so live
       playback dies silently with a console-only refusal. The Tizen-namespaced
       element is the only CSP the platform actually enforces. Mirror the meta
       tag directives so the two surfaces stay aligned. -->
  <tizen:content-security-policy>default-src 'none'; script-src 'self'; style-src 'self'; img-src 'self' data:; font-src 'self'; connect-src 'self' https://hls.irannrtv.live; media-src https://hls.irannrtv.live blob:; object-src 'none'; base-uri 'self'; form-action 'none'; worker-src 'none'; frame-src 'none'</tizen:content-security-policy>
  <access origin="https://hls.irannrtv.live" subdomains="false"/>
  <tizen:allow-navigation>https://hls.irannrtv.live</tizen:allow-navigation>
  <!-- tv.inputdevice: required for tizen.tvinputdevice.registerKey() to
       capture MediaPlay/Pause/PlayPause/Stop from the remote. Without this
       privilege the registrations silently no-op on real hardware (the
       transport keys still fire on the system, not the app). -->
  <tizen:privilege name="http://tizen.org/privilege/tv.inputdevice"/>
  <feature name="http://tizen.org/feature/screen.size.normal.1080.1920"/>
</widget>
